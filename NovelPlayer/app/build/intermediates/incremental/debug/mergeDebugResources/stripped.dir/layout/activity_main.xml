<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- 顶部标题栏 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:background="@color/surface"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="小说播放器"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- 标签页 -->
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tab_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/surface"
            app:tabTextColor="@color/text_secondary"
            app:tabSelectedTextColor="@color/primary"
            app:tabIndicatorColor="@color/primary">

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="听小说" />

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="音频探测" />

        </com.google.android.material.tabs.TabLayout>

        <!-- 内容区域 -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <!-- 听小说页面 -->
            <FrameLayout
                android:id="@+id/novel_page"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <!-- 首页输入 -->
                <ScrollView
                    android:id="@+id/novel_home"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:visibility="visible">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <androidx.cardview.widget.CardView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:cardBackgroundColor="@color/surface"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="20dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="输入小说播放地址"
                                    android:textColor="@color/accent"
                                    android:textSize="16sp"
                                    android:textStyle="bold"
                                    android:layout_marginBottom="12dp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="支持 i275.com 等小说网站"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="13sp"
                                    android:layout_marginBottom="8dp" />

                                <EditText
                                    android:id="@+id/novel_url_input"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:background="@drawable/bg_input"
                                    android:padding="12dp"
                                    android:textColor="@color/text_primary"
                                    android:textSize="14sp"
                                    android:hint="https://m.i275.com/play/101/132611.html"
                                    android:textColorHint="@color/text_secondary"
                                    android:inputType="textUri"
                                    android:layout_marginBottom="12dp" />

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/start_play_btn"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="开始播放"
                                    android:textColor="@android:color/white"
                                    app:backgroundTint="@color/primary"
                                    app:cornerRadius="10dp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="提示：输入任意章节地址即可，程序会自动加载目录并支持上下章切换"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="12sp"
                                    android:layout_marginTop="10dp" />

                            </LinearLayout>

                        </androidx.cardview.widget.CardView>

                    </LinearLayout>

                </ScrollView>

                <!-- 播放器界面 -->
                <ScrollView
                    android:id="@+id/novel_player"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <!-- 书籍信息 -->
                        <androidx.cardview.widget.CardView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:cardBackgroundColor="@color/surface"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp"
                            android:layout_marginBottom="16dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:padding="16dp">

                                <ImageView
                                    android:id="@+id/book_cover"
                                    android:layout_width="80dp"
                                    android:layout_height="100dp"
                                    android:scaleType="centerCrop"
                                    android:background="@color/surface_variant" />

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical"
                                    android:layout_marginStart="16dp">

                                    <TextView
                                        android:id="@+id/book_title"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:textColor="@color/text_primary"
                                        android:textSize="18sp"
                                        android:textStyle="bold"
                                        android:maxLines="1"
                                        android:ellipsize="end" />

                                    <TextView
                                        android:id="@+id/chapter_title"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:textColor="@color/accent"
                                        android:textSize="14sp"
                                        android:maxLines="1"
                                        android:ellipsize="end"
                                        android:layout_marginTop="4dp" />

                                    <TextView
                                        android:id="@+id/book_meta"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:textColor="@color/text_secondary"
                                        android:textSize="12sp"
                                        android:layout_marginTop="6dp" />

                                </LinearLayout>

                            </LinearLayout>

                        </androidx.cardview.widget.CardView>

                        <!-- 播放控制 -->
                        <androidx.cardview.widget.CardView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:cardBackgroundColor="@color/surface"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp"
                            android:layout_marginBottom="16dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="20dp">

                                <SeekBar
                                    android:id="@+id/progress_seek"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="8dp" />

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:layout_marginBottom="16dp">

                                    <TextView
                                        android:id="@+id/current_time"
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:text="00:00"
                                        android:textColor="@color/text_secondary"
                                        android:textSize="12sp" />

                                    <TextView
                                        android:id="@+id/total_time"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="00:00"
                                        android:textColor="@color/text_secondary"
                                        android:textSize="12sp" />

                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center"
                                    android:layout_marginBottom="12dp">

                                    <com.google.android.material.button.MaterialButton
                                        android:id="@+id/prev_chapter_btn"
                                        style="@style/Widget.MaterialComponents.Button.TextButton"
                                        android:layout_width="48dp"
                                        android:layout_height="48dp"
                                        android:insetLeft="0dp"
                                        android:insetTop="0dp"
                                        android:insetRight="0dp"
                                        android:insetBottom="0dp"
                                        android:text="上一曲"
                                        android:textSize="12sp"
                                        app:iconPadding="0dp"
                                        app:cornerRadius="24dp" />

                                    <com.google.android.material.button.MaterialButton
                                        android:id="@+id/play_pause_btn"
                                        android:layout_width="56dp"
                                        android:layout_height="56dp"
                                        android:layout_marginStart="12dp"
                                        android:layout_marginEnd="12dp"
                                        android:insetLeft="0dp"
                                        android:insetTop="0dp"
                                        android:insetRight="0dp"
                                        android:insetBottom="0dp"
                                        android:text="播放"
                                        android:textSize="14sp"
                                        app:backgroundTint="@color/primary"
                                        app:iconPadding="0dp"
                                        app:cornerRadius="28dp" />

                                    <com.google.android.material.button.MaterialButton
                                        android:id="@+id/next_chapter_btn"
                                        style="@style/Widget.MaterialComponents.Button.TextButton"
                                        android:layout_width="48dp"
                                        android:layout_height="48dp"
                                        android:insetLeft="0dp"
                                        android:insetTop="0dp"
                                        android:insetRight="0dp"
                                        android:insetBottom="0dp"
                                        android:text="下一曲"
                                        android:textSize="12sp"
                                        app:iconPadding="0dp"
                                        app:cornerRadius="24dp" />

                                </LinearLayout>

                                <!-- 播放速度 -->
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center">

                                    <com.google.android.material.button.MaterialButton
                                        android:id="@+id/speed_075_btn"
                                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginEnd="4dp"
                                        android:text="0.75x"
                                        android:textSize="11sp"
                                        android:textColor="@color/text_secondary"
                                        app:strokeColor="@color/surface_variant"
                                        app:cornerRadius="6dp" />

                                    <com.google.android.material.button.MaterialButton
                                        android:id="@+id/speed_1_btn"
                                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginEnd="4dp"
                                        android:text="1x"
                                        android:textSize="11sp"
                                        android:textColor="@android:color/white"
                                        app:strokeColor="@color/primary"
                                        app:backgroundTint="@color/primary"
                                        app:cornerRadius="6dp" />

                                    <com.google.android.material.button.MaterialButton
                                        android:id="@+id/speed_125_btn"
                                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginEnd="4dp"
                                        android:text="1.25x"
                                        android:textSize="11sp"
                                        android:textColor="@color/text_secondary"
                                        app:strokeColor="@color/surface_variant"
                                        app:cornerRadius="6dp" />

                                    <com.google.android.material.button.MaterialButton
                                        android:id="@+id/speed_15_btn"
                                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginEnd="4dp"
                                        android:text="1.5x"
                                        android:textSize="11sp"
                                        android:textColor="@color/text_secondary"
                                        app:strokeColor="@color/surface_variant"
                                        app:cornerRadius="6dp" />

                                    <com.google.android.material.button.MaterialButton
                                        android:id="@+id/speed_2_btn"
                                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="2x"
                                        android:textSize="11sp"
                                        android:textColor="@color/text_secondary"
                                        app:strokeColor="@color/surface_variant"
                                        app:cornerRadius="6dp" />

                                </LinearLayout>

                            </LinearLayout>

                        </androidx.cardview.widget.CardView>

                        <!-- 章节列表 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="12dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="章节列表"
                                android:textColor="@color/accent"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/chapter_count"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="@color/text_secondary"
                                android:textSize="14sp" />

                        </LinearLayout>

                        <EditText
                            android:id="@+id/chapter_search"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_input"
                            android:padding="12dp"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            android:hint="搜索章节..."
                            android:textColorHint="@color/text_secondary"
                            android:inputType="text"
                            android:layout_marginBottom="12dp" />

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/chapter_list"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_card"
                            android:nestedScrollingEnabled="false" />

                    </LinearLayout>

                </ScrollView>

            </FrameLayout>

            <!-- 音频探测页面 -->
            <ScrollView
                android:id="@+id/detect_page"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- URL 检测 -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardBackgroundColor="@color/surface"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        android:layout_marginBottom="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="20dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="通过 URL 抓取"
                                android:textColor="@color/accent"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:layout_marginBottom="12dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="输入网页地址"
                                android:textColor="@color/text_secondary"
                                android:textSize="13sp"
                                android:layout_marginBottom="8dp" />

                            <EditText
                                android:id="@+id/detect_url_input"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="@drawable/bg_input"
                                android:padding="12dp"
                                android:textColor="@color/text_primary"
                                android:textSize="14sp"
                                android:hint="https://example.com/page.html"
                                android:textColorHint="@color/text_secondary"
                                android:inputType="textUri"
                                android:layout_marginBottom="12dp" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/detect_url_btn"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="检测"
                                    android:textColor="@android:color/white"
                                    app:backgroundTint="@color/primary"
                                    app:cornerRadius="10dp" />

                            </LinearLayout>

                        </LinearLayout>

                    </androidx.cardview.widget.CardView>

                    <!-- 源码检测 -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardBackgroundColor="@color/surface"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        android:layout_marginBottom="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="20dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="粘贴源码"
                                android:textColor="@color/accent"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:layout_marginBottom="12dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="复制网页源码粘贴到下方"
                                android:textColor="@color/text_secondary"
                                android:textSize="13sp"
                                android:layout_marginBottom="8dp" />

                            <EditText
                                android:id="@+id/detect_source_input"
                                android:layout_width="match_parent"
                                android:layout_height="150dp"
                                android:background="@drawable/bg_input"
                                android:padding="12dp"
                                android:textColor="@color/text_primary"
                                android:textSize="12sp"
                                android:hint="粘贴 HTML 源码..."
                                android:textColorHint="@color/text_secondary"
                                android:inputType="textMultiLine"
                                android:gravity="top|start"
                                android:scrollbars="vertical"
                                android:layout_marginBottom="12dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/detect_source_btn"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="检测"
                                android:textColor="@android:color/white"
                                app:backgroundTint="@color/primary"
                                app:cornerRadius="10dp" />

                        </LinearLayout>

                    </androidx.cardview.widget.CardView>

                    <!-- 检测结果 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="检测结果"
                            android:textColor="@color/accent"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/detect_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_badge"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:paddingTop="3dp"
                            android:paddingBottom="3dp"
                            android:text="0"
                            android:textColor="@android:color/white"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/detect_results_list"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false" />

                </LinearLayout>

            </ScrollView>

        </FrameLayout>

    </LinearLayout>

    <!-- 加载遮罩 -->
    <FrameLayout
        android:id="@+id/loading_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#D9000000"
        android:visibility="gone"
        android:clickable="true">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center">

            <ProgressBar
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/loading_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="加载中..."
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

        </LinearLayout>

    </FrameLayout>

</FrameLayout>
